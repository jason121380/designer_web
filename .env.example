# 資料庫 (Zeabur 自動注入 PostgreSQL 連線字串)
DATABASE_URL="postgresql://user:password@localhost:5432/designer_web"

# Auth.js - 產生隨機密鑰: openssl rand -base64 32
AUTH_SECRET="your-secret-key-at-least-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# 網站正式網址（SEO、sitemap、JSON-LD 使用；正式環境與 NEXTAUTH_URL 同網域）
SITE_URL="http://localhost:3000"

# Cloudflare R2（圖片；五個變數都設定才會啟用，否則退回本機 / Zeabur Volume 的 public/uploads）
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET=""
CLOUDFLARE_R2_PUBLIC_URL="https://media.example.com"

# Cloudflare Stream（影片 direct upload API 使用；前台影片欄位填 Stream 播放 URL）
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_STREAM_API_TOKEN=""

# 選用：db:seed 建立的管理員帳號（未設定時為 admin@mifaso.com / admin123456）
# SEED_ADMIN_EMAIL=""
# SEED_ADMIN_PASSWORD=""
# SEED_ADMIN_NAME=""

# 選用：Google Search Console 驗證
# GOOGLE_SITE_VERIFICATION=""

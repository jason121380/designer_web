# 資料庫 (Zeabur 自動注入 PostgreSQL 連線字串)
DATABASE_URL="postgresql://user:password@localhost:5432/luxe_magazine"

# Auth.js - 產生隨機密鑰: openssl rand -base64 32
AUTH_SECRET="your-secret-key-at-least-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# 網站設定
SITE_NAME="MIFASO"
SITE_URL="http://localhost:3000"

# OpenAI（AI 摘要 / SEO / 標籤功能，app/api/ai/route.ts 使用）
OPENAI_API_KEY="sk-..."

# Cloudflare R2（圖片；未設定時會退回本機 / Zeabur Volume 的 public/uploads）
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET=""
CLOUDFLARE_R2_PUBLIC_URL="https://media.example.com"

# Cloudflare Stream（影片；後台影片上傳會直接傳到 Stream）
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_STREAM_API_TOKEN=""
